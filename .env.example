# Archivo .env.example
# Este es un EJEMPLO de cómo debe verse tu archivo .env

# ========= MOTOR DE BASE DE DATOS =========
# sqlite  → desarrollo local (sin configuración extra)
# mysql   → producción en EC2
DB_ENGINE=sqlite

# ========= SQLITE (solo si DB_ENGINE=sqlite) =========
SQLITE_PATH=crypto_prices.db

# ========= MYSQL (solo si DB_ENGINE=mysql) =========
MYSQL_HOST=tu_ip_ec2_aqui
MYSQL_USER=tu_usuario_mysql
MYSQL_PASSWORD=tu_contrasena_mysql
MYSQL_DATABASE=crypto_db

# ========= API KEYS =========
COINGECKO_API_KEY=tu_api_key_de_coingecko