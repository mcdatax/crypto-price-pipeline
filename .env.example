# Archivo .env.example
# Este es un EJEMPLO de cómo debe verse tu archivo .env
# NO pongas tus credenciales reales aquí
# Este archivo SÍ se puede subir a GitHub como documentación

# --- INSTRUCCIONES ---
# 1. Copia este archivo y renómbralo a ".env" (sin .example)
# 2. Reemplaza los valores de ejemplo con tus credenciales reales
# 3. El archivo .env NO se subirá a GitHub (está en .gitignore)

# Credenciales de Twilio (obtén las tuyas en: https://console.twilio.com)
TWILIO_ACCOUNT_SID=tu_account_sid_aqui
TWILIO_AUTH_TOKEN=tu_auth_token_aqui
TWILIO_PHONE_NUMBER=+1234567890

# API Key de Weather API (obtén la tuya en: https://www.weatherapi.com)
API_KEY_WAPI=tu_api_key_aqui

# Número de destino (a quien enviarás los mensajes SMS, formato E.164)
PHONE_NUMBER_DESTINATION=+34612345678
